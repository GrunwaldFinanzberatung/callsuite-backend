{
  "version": 2,
  "crons": [
    {
      "path": "/api/sheets-sync",
      "schedule": "0 */2 * * *"
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/formular/(.*)", "dest": "/public/formular.html" },
    { "src": "/formular", "dest": "/public/formular.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
